# ── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_DB=dimensionlab
POSTGRES_USER=dluser
POSTGRES_PASSWORD=change-me

# ── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=change-me
JWT_EXPIRATION_SECONDS=86400

# ── OAuth2 Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost
COOKIE_SECURE=true
ADMIN_EMAILS=

# ── WhatsApp (Evolution API) ─────────────────────────────────────────────────
EVOLUTION_ENABLED=false
EVOLUTION_BASE_URL=
EVOLUTION_INSTANCE=
EVOLUTION_ADMIN_NUMBER=

# ── Portas ───────────────────────────────────────────────────────────────────
HTTP_PORT=80

# ── Spring Profile ───────────────────────────────────────────────────────────
# Não altere em produção — ativa application-prod.yml
SPRING_PROFILES_ACTIVE=prod